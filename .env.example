# Base de données — Neon (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better-Auth
BETTER_AUTH_SECRET=change-me-in-production-32-chars-min
BETTER_AUTH_URL=http://localhost:3000
# prod : BETTER_AUTH_URL=https://lister.meerai.lab

# Typesense (serveur — admin key)
# dev  : TYPESENSE_HOST=localhost
# prod : TYPESENSE_HOST=typesense (nom du service Docker)
TYPESENSE_ADMIN_API_KEY=local-dev-key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# Typesense (clé read-only, exposable côté client — générer via : bun run search:create-key)
# dev  : VITE_TYPESENSE_HOST=localhost
# prod : VITE_TYPESENSE_HOST=typesense.meerai.lab + PORT=443 + PROTOCOL=https
VITE_TYPESENSE_SEARCH_API_KEY=local-search-key
VITE_TYPESENSE_HOST=localhost
VITE_TYPESENSE_PORT=8108
VITE_TYPESENSE_PROTOCOL=http

# PostHog (https://posthog.com — clé publique, ok d'exposer)
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://eu.i.posthog.com
